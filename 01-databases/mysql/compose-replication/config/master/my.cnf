[mysqld]
# 生产基线：统一字符集，避免乱码与排序不一致
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

# 生产基线：减少 DNS 反查带来的连接抖动（配合用户使用 IP 或显式 host）
skip_name_resolve = ON

# 生产基线：事务与 binlog 的一致性（GTID 复制依赖）
server-id = 1
log_bin = mysql-bin
binlog_format = ROW
binlog_row_image = FULL
binlog_expire_logs_seconds = 604800
sync_binlog = 1

gtid_mode = ON
enforce_gtid_consistency = ON

# 生产基线：复制元信息落表，崩溃恢复更可靠
master_info_repository = TABLE
relay_log_info_repository = TABLE

# 生产基线：建议开启，便于未来需要“级联/切换”时的可扩展性
log_replica_updates = ON

# 生产基线：InnoDB 自动按实例内存做 sizing（容器建议启用，避免手工误配）
innodb_dedicated_server = ON

# 生产基线：InnoDB 刷盘策略（性能/可靠性权衡）
innodb_flush_log_at_trx_commit = 1

# 生产基线：降低双写放大与延迟抖动（依赖宿主机/卷支持）
innodb_flush_method = O_DIRECT

# 生产基线：连接与资源上限（需要按业务与内存评估）
max_connections = 1000
table_open_cache = 4096
open_files_limit = 65535

# 生产基线：慢查询排障（建议配合采样与集中采集）
slow_query_log = ON
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 0.5

[client]
default-character-set = utf8mb4
